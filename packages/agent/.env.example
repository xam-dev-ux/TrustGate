# XMTP Configuration
XMTP_WALLET_KEY=your_xmtp_wallet_private_key_here
XMTP_DB_ENCRYPTION_KEY=your_32_char_encryption_key_here
XMTP_ENV=production

# Neynar API for basename resolution
NEYNAR_API_KEY=your_neynar_api_key_here

# Contract Addresses
CONTRACT_ADDRESS=deployed_trustgate_registry_address
STAKING_POOL_ADDRESS=deployed_staking_pool_address
TRUSTSCORE_NFT_ADDRESS=deployed_trustscore_nft_address
ERC8004_REGISTRY_ADDRESS=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
ERC8183_FACTORY_ADDRESS=

# Blockchain Configuration
RPC_URL=https://mainnet.base.org
BASESCAN_API_KEY=your_basescan_api_key_here

# Operator Configuration (DO NOT COMMIT)
OPERATOR_PRIVATE_KEY=your_operator_private_key_here

# Fee Configuration (in USDC)
CERTIFICATION_FEE_USDC=0.10
EVALUATION_FEE_USDC=0.05

# Certification Configuration
CERT_EXPIRY_DAYS=90

# Treasury
TREASURY_ADDRESS=your_treasury_address_here

# Server Configuration
PORT=3001

# Timeouts
SKILL_FETCH_TIMEOUT_MS=5000

# Evaluator JSON Updater
EVALUATOR_UPDATE_INTERVAL_MS=3600000
EVALUATOR_JSON_PATH=
