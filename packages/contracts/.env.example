# Base mainnet RPC URL
BASE_RPC_URL=https://mainnet.base.org

# Deployer private key (DO NOT COMMIT)
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here

# Basescan API key for contract verification
BASESCAN_API_KEY=your_basescan_api_key_here

# Operator private key for recordCertification/recordEvaluation (DO NOT COMMIT)
OPERATOR_PRIVATE_KEY=your_operator_private_key_here

# Treasury address for fee collection
TREASURY_ADDRESS=your_treasury_address_here

# USDC address (Base mainnet, DO NOT change)
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Contract addresses (filled after deployment)
CONTRACT_ADDRESS=
STAKING_POOL_ADDRESS=
TRUSTSCORE_NFT_ADDRESS=

# Staking Pool Configuration (in USDC, min 0.1)
STAKE_MIN_CONDITIONAL=0.1
STAKE_MIN_TRUSTED=1
STAKE_MIN_VERIFIED=10
STAKE_LEVERAGE_MULTIPLIER=5
